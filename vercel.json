{
  "functions": {
    "api/bot.py": {
      "runtime": "@vercel/python@4.3.0",
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/webhook", "destination": "/api/bot" },
    { "source": "/setup", "destination": "/api/bot" },
    { "source": "/debug", "destination": "/api/bot" },
    { "source": "/", "destination": "/api/bot" }
  ]
}
